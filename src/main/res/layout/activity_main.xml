<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1B1B2F"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KREEDA-ANKANA"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FF6B00"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Village Sports Organizer"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnCalendar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Ground Calendar"
        android:textSize="16sp"
        android:backgroundTint="#FF6B00"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnChallenge"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Challenge Board"
        android:textSize="16sp"
        android:backgroundTint="#E63946"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnScore"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Score Wall"
        android:textSize="16sp"
        android:backgroundTint="#2EC4B6"/>

</LinearLayout>