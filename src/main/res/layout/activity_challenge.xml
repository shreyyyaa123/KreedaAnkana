<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1B2F">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Challenge Board"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E63946"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etTeamName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your Team Name"
            android:textColorHint="#AAAAAA"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etChallengeMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Challenge Message"
            android:textColorHint="#AAAAAA"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnPostChallenge"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Post Challenge"
            android:backgroundTint="#E63946"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Challenges"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FF6B00"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/challengeList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</ScrollView>